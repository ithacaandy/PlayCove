
import Header from "../components/Header";
import { createServerSupabase } from "../../lib/supabase-server";
import { redirect } from "next/navigation";

export default async function GroupsPage(){
  const s = createServerSupabase();
  const { data: { user } } = await s.auth.getUser();
  if (!user) redirect("/auth?next=/groups");

  const { data: mine } = await s
    .from("group_members")
    .select("group_id, status, role, groups!inner(id,name,description)")
    .eq("user_id", user.id);

  return (
    <main>
      {/* @ts-expect-error Async Server Component */}
      <Header />
      <div className="container py-6 space-y-6">
        <div className="flex items-center justify-between">
          <h1 className="text-xl font-semibold">Groups</h1>
          <div className="flex gap-2">
            <a className="btn btn-ghost" href="/groups/new">+ New Group</a>
            <a className="btn btn-primary" href="/groups/discover">Discover Groups</a>
          </div>
        </div>

        <section className="grid md:grid-cols-2 gap-4">
          {(mine||[]).map(m => (
            <div key={m.groups.id} className="card p-4 flex items-center justify-between">
              <div>
                <div className="font-medium">{m.groups.name}</div>
                <div className="text-sm text-neutral-600">{m.groups.description}</div>
                <div className="text-xs text-neutral-500 mt-1">role: {m.role} · status: {m.status}</div>
              </div>
              <div className="flex gap-2">
                <a className="btn btn-ghost" href={`/?group=${m.groups.id}`}>Open</a>
                {(m.role === "owner" || m.role === "admin") && (
                  <>
                    <a className="btn btn-ghost" href={`/groups/${m.groups.id}/members`}>Manage</a>
                    <a className="btn btn-ghost" href={`/groups/${m.groups.id}/invite`}>Invite</a>
                  </>
                )}
              </div>
            </div>
          ))}
          {(mine||[]).length===0 && <div className="card p-6 text-neutral-600">You’re not in any groups yet.</div>}
        </section>
      </div>
    </main>
  );
}
