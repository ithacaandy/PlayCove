
import Header from "../../components/Header";
import { createServerSupabase } from "../../../lib/supabase-server";
import { redirect } from "next/navigation";

export default async function Discover({ searchParams }){
  const s = createServerSupabase();
  const { data: { user } } = await s.auth.getUser();
  if (!user) redirect("/auth?next=/groups/discover");

  const q = (searchParams?.q || "").trim();
  let query = s.from("groups").select("id,name,description,is_discoverable").eq("is_discoverable", true);
  if (q) query = query.or(`name.ilike.%${q}%,description.ilike.%${q}%`);
  const { data: rows } = await query.order("created_at", { ascending: false });

  return (
    <main>
      {/* @ts-expect-error Async Server Component */}
      <Header />
      <div className="container py-6 space-y-4">
        <div className="flex items-center justify-between">
          <h1 className="text-xl font-semibold">Discover Groups</h1>
          <a href="/groups" className="btn btn-ghost">My Groups</a>
        </div>

        <form className="card p-4 flex gap-2" method="get">
          <input className="input flex-1" name="q" placeholder="Search by city, neighborhood, or group name" defaultValue={q} />
          <button className="btn btn-primary">Search</button>
          {q && <a className="btn btn-ghost" href="/groups/discover">Reset</a>}
        </form>

        <div className="grid md:grid-cols-2 gap-4">
          {(rows || []).map(g => (
            <div key={g.id} className="card p-4 flex items-center justify-between">
              <div>
                <div className="font-medium">{g.name}</div>
                <div className="text-sm text-neutral-600">{g.description}</div>
              </div>
              <form method="post" action={`/api/groups/request?group=${g.id}`}>
                <button className="btn btn-ghost">Request to join</button>
              </form>
            </div>
          ))}
          {(rows || []).length===0 && (
            <div className="card p-6 text-neutral-600">No groups found. Try a different city or keyword.</div>
          )}
        </div>
      </div>
    </main>
  );
}
